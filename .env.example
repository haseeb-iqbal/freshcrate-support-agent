# --- Database (Postgres + pgvector) ---
# Local Docker default (see docker-compose.yml). Swap for your Supabase pooled
# connection string for cloud/Vercel deploys — schema and seed are identical.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/freshcrate

# --- Model providers (used from Phase 1 onward; not required for Phase 0) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Tunable guardrails / cost controls (defaults confirmed in Phase 4 / 6) ---
REFUND_CEILING_CENTS=5000
MAX_LOOP_ITERATIONS=6
MAX_OUTPUT_TOKENS=1024
RATE_LIMIT_PER_MIN=20
