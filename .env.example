# --- Database (Postgres + pgvector) ---
# Local Docker default (see docker-compose.yml). Swap for your Supabase pooled
# connection string for cloud/Vercel deploys — schema and seed are identical.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/freshcrate

# --- Model provider: OpenAI powers both chat and embeddings ---
# (used from Phase 1 onward; not required for Phase 0)
OPENAI_API_KEY=

# Model selection. CHAT_MODEL_FAST handles simple turns; CHAT_MODEL_SMART is
# used for complex multi-step reasoning (model routing, Phase 6).
CHAT_MODEL_FAST=gpt-4o-mini
CHAT_MODEL_SMART=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Tunable guardrails / cost controls (defaults confirmed in Phase 4 / 6) ---
# Refunds self-serve at or below this ceiling AND at most one per 14 days.
REFUND_CEILING_CENTS=2000
# One-time fee to reactivate a cancelled subscription past its billing date.
SIGNUP_FEE_CENTS=4000
MAX_LOOP_ITERATIONS=6
MAX_OUTPUT_TOKENS=1024
RATE_LIMIT_PER_MIN=20
