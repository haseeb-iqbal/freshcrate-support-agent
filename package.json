{
  "name": "freshcrate-support-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic AI customer support assistant for FreshCrate (portfolio project)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:enable-vector": "tsx db/enable-vector.ts",
    "db:push": "npm run db:enable-vector && drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "npm run db:enable-vector && drizzle-kit push && npm run db:seed",
    "kb:ingest": "tsx kb/ingest.ts",
    "kb:test": "tsx scripts/test-retrieval.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "next": "^14.2.15",
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
