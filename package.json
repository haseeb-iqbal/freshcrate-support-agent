{
  "name": "freshcrate-support-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic AI customer support assistant for FreshCrate (portfolio project)",
  "scripts": {
    "dev": "next dev",
    "dev:mock": "cross-env MOCK_LLM=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:enable-vector": "tsx db/enable-vector.ts",
    "db:push": "npm run db:enable-vector && drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "npm run db:enable-vector && drizzle-kit push && npm run db:seed",
    "kb:ingest": "tsx kb/ingest.ts",
    "kb:test": "tsx scripts/test-retrieval.ts",
    "test": "cross-env TZ=UTC vitest run",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:api": "cross-env TZ=UTC vitest run --config vitest.api.config.ts",
    "test:integration": "cross-env TZ=UTC vitest run --config vitest.integration.config.ts",
    "test:coverage": "cross-env TZ=UTC vitest run --coverage",
    "test:all": "npm run typecheck && npm test && npm run test:integration",
    "test:e2e": "npm run db:reset && start-server-and-test dev:mock http://localhost:3000 cypress",
    "typecheck": "tsc --noEmit",
    "cypress": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "next": "^14.2.15",
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "cypress": "^15.18.1",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
